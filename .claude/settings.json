{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git commit:*)",
      "Bash(bun dev:*)",
      "Bash(bun test:*)",
      "Bash(bun check:*)",
      "Bash(bun typecheck *)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/bin/**)",
      "Read(**/obj/**)",
      "Bash(cat .env:*)",
      "Edit(**/.env)",
      "Write(**/.env)"
    ]
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "auto",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -l scripts/create-worktree.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "fp=$(jq -r '.tool_input.file_path // empty'); case \"$fp\" in */packages/web/*) out=$(cd \"$CLAUDE_PROJECT_DIR/packages/web\" && bunx vp check --fix \"$fp\" 2>&1) || { echo \"$out\"; exit 2; } ;; esac"
          }
        ]
      }
    ]
  }
}
