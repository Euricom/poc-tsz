# API base URL (the C# backend)
SERVER_URL=http://localhost:5204

# Microsoft OAuth (Azure App Registration in the Euricom tenant)
# - Redirect URI in Azure: http://localhost:3000/api/auth/callback/microsoft
# - "Accounts in this organizational directory only" (single tenant)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_TENANT_ID=

# better-auth
# Generate a 32-byte hex secret:
#   bun -e "console.log(crypto.randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Path to the shared SQLite DB used by better-auth.
# Defaults to <repo-root>/db/tsz.db (resolved relative to auth.server.ts).
# AUTH_DB_PATH=../../db/tsz.db
