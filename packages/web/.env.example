# API base URL (the API backend)
SERVER_URL=http://localhost:5204

# Application base URL (the hosting domain)
APP_BASE_URL=http://localhost:3000

# Microsoft OAuth (Azure App Registration in the Euricom tenant)
# - Redirect URI in Azure: http://localhost:3000/api/auth/callback/microsoft
# - "Accounts in this organizational directory only" (single tenant)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_TENANT_ID=

# Session management (BetterAuth)
# A 32-byte hex secret:
AUTH_COOKIE_SECRET=

# URL of the SQLite DB used by the auth (file: prefix supported)
# AUTH_DB_URL=file:./auth.db
