{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git status:*)",
      "Bash(git commit:*)",
      "Bash(bun dev:*)",
      "Bash(bun test:*)",
      "Bash(bun check:*)",
      "Bash(bun typecheck *)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(**/node_modules/**)",
      "Read(**/dist/**)",
      "Read(**/build/**)",
      "Read(**/bin/**)",
      "Read(**/obj/**)",
      "Bash(cat .env:*)", 
      "Edit(**/.env)", 
      "Write(**/.env)"
    ]
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "auto"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -l scripts/create-worktree.sh"
          }
        ]
      }
    ],
    "PostToolUse": [{
      "matcher": "Edit|Write",
      "hooks": [{ "type": "command", "command": "cd packages/web && out=$(bun check 2>&1) || echo \"$out\"" }]
    }]
  }
}