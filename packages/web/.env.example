# API base URL (the API backend)
SERVER_URL=http://localhost:5204

# Application base URL (the hosting domain)
APP_BASE_URL=http://localhost:3000

# Microsoft OAuth (Azure App Registration in the Euricom tenant)
# - Redirect URI in Azure: http://localhost:3000/api/auth/callback/microsoft-entra-id
# - "Accounts in this organizational directory only" (single tenant)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_TENANT_ID=

# Auth.js session secret (≥ 32 bytes base64). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=
